{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "Successor Recipe App",
        "supportEmail": "mpalmeralt@gmail.com"
      }
    }
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "src/**",
      "tests/**",
      ".git/**",
      ".github/**",
      ".agents/**",
      "run.bat",
      "tsconfig.json",
      "package.json",
      "package-lock.json",
      "skills-lock.json",
      "firestore.rules",
      "firestore.indexes.json"
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
