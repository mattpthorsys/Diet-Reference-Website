rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Allow read/write access only if user is logged in with a Google account
      // and their email address belongs to the @thorsys.com.au domain.
      allow read, write: if request.auth != null && request.auth.token.email.matches('.*@thorsys.com.au');
    }
  }
}
